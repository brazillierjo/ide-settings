{
  // ─── Theme ────────────────────────────────────────────
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "theme": {
    "mode": "system",
    "light": "Gruvbox Light Hard",
    "dark": "Ayu Dark",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },

  // ─── Typography ───────────────────────────────────────
  "ui_font_family": "Maple Mono NF",
  "ui_font_size": 16,
  "buffer_font_family": "Maple Mono NF",
  "buffer_font_size": 15,
  "buffer_font_weight": 400,
  "buffer_line_height": "comfortable",
  "buffer_font_features": {
    "calt": true, // ligatures contextuelles
    "liga": true, // ligatures standard (=> !== <=)
    "cv01": true, // variantes styliques (alt @, alt &)
  },

  // ─── Editor ───────────────────────────────────────────
  "cursor_shape": "underline",
  "soft_wrap": "editor_width",
  "show_whitespaces": "boundary",
  "tab_size": 2,
  "format_on_save": "on",
  "autosave": "on_focus_change",
  "relative_line_numbers": "disabled",

  // ─── Indent guides ───────────────────────────────────
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },

  // ─── Inlay hints ─────────────────────────────────────
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": false,
    "show_other_hints": true,
  },

  // ─── Scrollbar (minimal) ─────────────────────────────
  "scrollbar": {
    "show": "auto",
    "cursors": false,
    "git_diff": true,
    "search_results": true,
    "diagnostics": "all",
  },

  // ─── Tab bar ──────────────────────────────────────────
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "close_position": "right",
    "git_status": true,
    "file_icons": true,
  },

  // ─── Toolbar (clean) ─────────────────────────────────
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": false,
  },

  // ─── Panels ───────────────────────────────────────────
  "project_panel": {
    "dock": "left",
    "default_width": 220,
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 20,
    "auto_fold_dirs": true,
    "hide_root": true,
    "hide_hidden": false,
    "hide_gitignore": false,
    "entry_spacing": "comfortable",
    "scrollbar": { "show": "never" },
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "notification_panel": {
    "dock": "left",
  },

  // ─── Git ──────────────────────────────────────────────
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 800,
    },
  },

  // ─── Terminal ─────────────────────────────────────────
  "terminal": {
    "font_family": "Maple Mono NF",
    "font_size": 13,
    "line_height": "comfortable",
    "dock": "bottom",
    "default_height": 320,
    "toolbar": { "breadcrumbs": false },
    "detect_venv": {
      "on": {
        "directories": [".venv", "venv", ".env", "env"],
        "activate_script": "default",
      },
    },
  },

  // ─── Centered layout (focused coding) ────────────────
  "centered_layout": {
    "left_padding": 0.12,
    "right_padding": 0.12,
  },

  // ─── Telemetry ────────────────────────────────────────
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  // ─── File scan exclusions ─────────────────────────────
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/.expo",
    "**/.next",
    "**/android",
    "**/ios/Pods",
    "**/.turbo",
  ],

  // ─── Language-specific ────────────────────────────────
  "languages": {
    "TypeScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--write"],
        },
      },
      "code_actions_on_format": {
        "source.organizeImports": true,
      },
    },
    "TSX": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--write"],
        },
      },
      "code_actions_on_format": {
        "source.organizeImports": true,
      },
    },
    "JavaScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--write"],
        },
      },
    },
    "JSON": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--write"],
        },
      },
    },
    "Python": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "ruff",
          "arguments": ["format", "--stdin-filename", "{buffer_path}"],
        },
      },
      "tab_size": 4,
    },
    "Markdown": {
      "soft_wrap": "editor_width",
      "format_on_save": "off",
    },
  },

  // ─── Auto-install extensions ──────────────────────────
  "auto_install_extensions": {
    "catppuccin-icons": true,
    "html": true,
    "toml": true,
    "docker-compose": true,
    "dockerfile": true,
    "git-firefly": true,
    "csv": true,
    "sql": true,
    "ruff": true,
  },
}
